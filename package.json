{
  "name": "just2guys",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "typecheck": "wrangler types && react-router typegen && tsc -b",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "pretest": "npm run test:data:prepare",
    "test": "vitest run",
    "test:data:prepare": "npm run import:legacy && npm run import:sleeper:snapshot",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "verify": "npm run typecheck && npm run lint && npm run test && npm run build",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "node --import tsx server/import/migrate-local.ts",
    "db:migrate:remote": "wrangler d1 migrations apply just2guys --remote",
    "db:seed:local": "node --import tsx server/import/seed-local.ts",
    "db:bootstrap:local": "npm run db:migrate:local && npm run import:legacy && npm run backfill:sleeper && npm run db:seed:local && npm run data:validate",
    "db:refresh:local": "npm run import:legacy && npm run import:sleeper:snapshot && npm run db:seed:local && npm run data:validate",
    "db:prepare:remote-import": "npm run test:data:prepare && node --import tsx server/import/prepare-remote-import.ts",
    "db:verify:remote-import": "node --import tsx server/import/verify-remote-import.ts",
    "db:import:remote": "node --import tsx server/import/apply-remote-import.ts",
    "import:legacy": "node --import tsx server/import/legacy.ts",
    "backfill:sleeper": "node --import tsx server/import/sleeper-backfill.ts",
    "import:sleeper:snapshot": "node --import tsx server/import/sleeper-from-snapshot.ts",
    "sync:remote": "node --import tsx server/sync/remote.ts",
    "manifests:validate": "node --import tsx server/import/validate-manifests.ts",
    "data:validate": "node --import tsx server/import/validate-local-data.ts",
    "release:check": "node --import tsx server/release/check.ts",
    "release:check:predeploy": "node --import tsx server/release/check.ts --predeploy",
    "release:verify:production": "node --import tsx server/release/verify-production.ts",
    "predeploy": "npm run release:check:predeploy",
    "deploy": "npm run build && wrangler deploy",
    "preview": "npm run build && vite preview",
    "cf-typegen": "wrangler types",
    "postinstall": "wrangler types"
  },
  "engines": {
    "node": ">=22.22.0"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "isbot": "^5.1.36",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "8.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@cloudflare/vite-plugin": "^1.45.1",
    "@cloudflare/vitest-pool-workers": "^0.18.6",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@react-router/dev": "8.0.0",
    "@types/node": "^22.20.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.10",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.6",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.65.0",
    "vite": "^8.0.3",
    "vitest": "^4.1.10",
    "wrangler": "^4.112.0"
  }
}
